{#-
  constraints.jinja (English)
  Output format + length caps (read dynamically from server `setting`).
  Expects: request_key, setting (optional)
  setting follows aiwolf_nlp_common.packet.Setting:
    - setting.talk.max_length.per_talk / per_agent / base_length
    - setting.whisper.max_length.per_talk / per_agent / base_length
-#}
{% if request_key == 'talk' -%}
{% if setting is not none and setting.talk is not none and setting.talk.max_length is not none and setting.talk.max_length.per_talk is not none -%}
Keep each utterance within {{ setting.talk.max_length.per_talk }} characters.
{% endif -%}
Output only the utterance. Do not include explanations, meta commentary, or preambles.
If you have nothing more to say, output "Over".
{% elif request_key == 'whisper' -%}
{% if setting is not none and setting.whisper is not none and setting.whisper.max_length is not none and setting.whisper.max_length.per_talk is not none -%}
Keep each whisper within {{ setting.whisper.max_length.per_talk }} characters.
{% endif -%}
Output only the whisper content. Do not include explanations, meta commentary, or preambles.
If you have nothing more to say, output "Over".
{% elif request_key in ['divine', 'guard', 'vote', 'attack'] -%}
Output only the target agent name. Do not add explanations, reasons, symbols, or prefixes.
{% endif -%}
